ANSIBLE_INVENTORY=./inventories/private-dev.ini
ANSIBLE_FLAGS=
ASK_BECOME_PASS=true
RUN_PRIVATE_DEV_SECRETS=false
RUN_ECR_SECRET=false

PRIVATE_DEV_LOCAL_DIR=.local/private-dev
PRIVATE_DEV_SSH_CONFIG=.local/private-dev/ssh_config
PRIVATE_DEV_SSH_SETUP_MARKER=.local/private-dev/ssh-setup.ready
PRIVATE_DEV_SSH_KEY=~/.ssh/medikong-private-dev
PRIVATE_DEV_SSH_PASSPHRASE=
PRIVATE_DEV_SSH_USER=lab-bum4496-833cff
PRIVATE_DEV_NODE1_HOST=external.terminal-lab.kr
PRIVATE_DEV_NODE1_PORT=41280
PRIVATE_DEV_NODE2_HOST=10.0.3.45
PRIVATE_DEV_NODE3_HOST=10.0.1.246
PRIVATE_DEV_NODE4_HOST=10.0.2.233
PRIVATE_DEV_NODE5_HOST=10.0.2.250
PRIVATE_DEV_NODE6_HOST=10.0.3.196

PRIVATE_DEV_ARGOCD_NAMESPACE=argocd
PRIVATE_DEV_ARGOCD_INSTALL_MANIFEST_URL=https://raw.githubusercontent.com/argoproj/argo-cd/stable/manifests/install.yaml
PRIVATE_DEV_ARGOCD_ROOT_APPLICATION_URL=https://raw.githubusercontent.com/TicketMong/gitops/main/argo/applications/private-dev/root.yaml
PRIVATE_DEV_ARGOCD_SERVER_READY_TIMEOUT=300s
PRIVATE_DEV_ARGOCD_CONTROLLER_READY_TIMEOUT=300s
PRIVATE_DEV_ARGOCD_ROOT_APPLICATION_NAME=medikong-private-dev-apps
