[control_plane]
%{ for name, node in nodes ~}
%{ if node.role == "control-plane" ~}
${name} ansible_host=${node.instance_id} ansible_aws_ssm_instance_id=${node.instance_id} node_ip=${node.private_ip} node_labels='${node.node_labels}' node_taints='${node.node_taints}'
%{ endif ~}
%{ endfor ~}

[workers]
%{ for name, node in nodes ~}
%{ if node.role == "worker" ~}
${name} ansible_host=${node.instance_id} ansible_aws_ssm_instance_id=${node.instance_id} node_ip=${node.private_ip} node_labels='${node.node_labels}' node_taints='${node.node_taints}'
%{ endif ~}
%{ endfor ~}

[app_workers]
%{ for name, node in nodes ~}
%{ if node.workload == "app" || node.workload == "app-data" ~}
${name}
%{ endif ~}
%{ endfor ~}

[platform_workers]
%{ for name, node in nodes ~}
%{ if node.workload == "platform" && node.role == "worker" ~}
${name}
%{ endif ~}
%{ endfor ~}

[data_workers]
%{ for name, node in nodes ~}
%{ if node.workload == "data" || node.workload == "app-data" ~}
${name}
%{ endif ~}
%{ endfor ~}

[observability_workers]
%{ for name, node in nodes ~}
%{ if node.workload == "observability" ~}
${name}
%{ endif ~}
%{ endfor ~}

[kube_control_plane:children]
control_plane

[kube_workers:children]
workers

[k8s_cluster:children]
control_plane
workers

[k8s_cluster:vars]
ansible_connection=amazon.aws.aws_ssm
ansible_aws_ssm_region=${aws_region}
ansible_aws_ssm_timeout=900
ansible_aws_ssm_bucket_name=${ansible_transfer_bucket_name}
ansible_aws_ssm_bucket_sse_mode=AES256
ansible_aws_ssm_s3_addressing_style=virtual
ansible_python_interpreter=/usr/bin/python3
ansible_become=true
ansible_become_method=sudo
ansible_become_user=root
